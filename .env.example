# === AI Providers for AdrAI Chatbot ===
# The chatbot tries providers in order: Groq → Mistral → Gemini
# Configure at least one for AI-powered responses; local KB is the final fallback.

# --- Groq (fastest inference) ---
VITE_GROQ_API_KEY=""
VITE_GROQ_MODEL="llama-3.3-70b-versatile"

# --- Mistral ---
VITE_MISTRAL_API_KEY=""
VITE_MISTRAL_MODEL="mistral-large-latest"

# --- Gemini (server-side proxy for production) ---
# Used by /api/gemini. This is the safest production Gemini path.
# If VITE_GEMINI_MODEL is unset, this server-side GEMINI_MODEL is used.
GEMINI_API_KEY="YOUR_SERVER_SIDE_API_KEY_HERE"
GEMINI_MODEL="gemini-2.5-pro"
GEMINI_ALLOWED_ORIGINS="https://adriel.dev,https://www.adriel.dev,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174"

# Optional for local Vite-only testing. Do not use client Gemini keys in production builds.
# If set, VITE_GEMINI_MODEL overrides the server-side GEMINI_MODEL for proxy requests.
VITE_GEMINI_API_KEY=""
VITE_GEMINI_MODEL="gemini-2.5-flash"
