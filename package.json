{
  "name": "adriel-portfolio",
  "version": "1.0.0",
  "description": "Adriel Magalona's Personal Portfolio Website",
  "main": "index.html",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --open \"/?admin=true\"",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "vercel --prod --yes",
    "deploy:preview": "vercel --yes",
    "refresh:github": "node scripts/generate-github-contributions.mjs",
    "check:links": "node scripts/check-links.mjs",
    "test:visual": "node scripts/visual-regression.mjs",
    "purge:css": "purgecss --css public/style.css --content index.html 'src/**/*.ts' --output ./public --safelist active open modal show hide loading article about background projects organizations faq achievements responsive-img-container progressive-img timeline-item timeline-list navbar-list sidebar-info",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "lighthouse": "lighthouse http://localhost:4173 --view --output=html --output-path=./lighthouse-report.html",
    "lighthouse:ci": "lhci autorun --config=./config/lighthouserc.json",
    "perf:audit": "npm run build && npm run preview & sleep 3 && npm run lighthouse && kill %1",
    "perf:budget": "lighthouse http://localhost:4173 --budget-path=./config/performance-budget.json --output=html --output-path=./budget-report.html"
  },
  "keywords": [
    "portfolio",
    "web-developer",
    "computer-science",
    "student",
    "typescript",
    "javascript",
    "html",
    "css"
  ],
  "author": "Adriel Magalona <dagsmagalona@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adr1el-m/portfolio"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.8.2",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.1.0",
    "lighthouse": "^12.2.1",
    "pa11y-ci": "^4.1.0",
    "puppeteer": "^24.27.0",
    "purgecss": "^7.0.2",
    "sharp": "^0.34.4",
    "terser": "^5.44.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "@types/three": "^0.180.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "firebase": "^12.8.0",
    "three": "^0.180.0",
    "vanilla-tilt": "^1.8.1",
    "web-vitals": "^5.1.0"
  },
  "overrides": {
    "esbuild": "0.25.11",
    "tmp": "0.2.7",
    "uuid": "11.1.1",
    "path-to-regexp": "0.1.13"
  }
}
