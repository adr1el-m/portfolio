# === AI Providers for AdrAI Chatbot ===
# The chatbot tries providers in order: Groq → Mistral → Gemini
# Configure at least one for AI-powered responses; local KB is the final fallback.

# --- Groq (fastest inference) ---
VITE_GROQ_API_KEY=""
VITE_GROQ_MODEL="llama-3.3-70b-versatile"

# --- Mistral ---
VITE_MISTRAL_API_KEY=""
VITE_MISTRAL_MODEL="mistral-large-latest"

# --- Gemini (server-side proxy for production) ---
# Used by /api/gemini. This is the safest production Gemini path.
# If VITE_GEMINI_MODEL is unset, this server-side GEMINI_MODEL is used.
GEMINI_API_KEY="YOUR_SERVER_SIDE_API_KEY_HERE"
GEMINI_MODEL="gemini-2.5-pro"
GEMINI_ALLOWED_ORIGINS="https://adriel.dev,https://www.adriel.dev,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174"

# Optional for local Vite-only testing. Do not use client Gemini keys in production builds.
# If set, VITE_GEMINI_MODEL overrides the server-side GEMINI_MODEL for proxy requests.
VITE_GEMINI_API_KEY=""
VITE_GEMINI_MODEL="gemini-2.5-flash"

# === Portfolio backend features ===
# Shared CORS allowlist for /api/contact and /api/analytics.
PORTFOLIO_ALLOWED_ORIGINS="https://adriel.dev,https://www.adriel.dev,http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174"

# Public Firebase client config for the visible Total Visits counter.
# Add these to .env locally if you want localhost to show the same live visit total as production.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_DATABASE_URL=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Optional private key for reading server analytics in the admin dashboard.
# Store the same value in localStorage as portfolio-admin-key when you want dashboard reads protected.
PORTFOLIO_ADMIN_KEY=""

# Optional persistent analytics store. Reuses Firebase Realtime Database when configured.
FIREBASE_DATABASE_URL=""
PORTFOLIO_ANALYTICS_FIREBASE_PATH="portfolioAnalytics/summary"
# Optional if your database rules require a server-side secret/token.
PORTFOLIO_FIREBASE_DATABASE_SECRET=""

# Optional contact delivery via Resend. Without RESEND_API_KEY, /api/contact accepts requests
# and the frontend falls back to the email draft flow.
RESEND_API_KEY=""
PORTFOLIO_CONTACT_TO="dagsmagalona@gmail.com"
PORTFOLIO_CONTACT_FROM="Portfolio <onboarding@resend.dev>"
PORTFOLIO_CONTACT_FIREBASE_PATH="portfolioContacts"
