{
  "ci": {
    "collect": {
      "url": ["http://localhost:4173"],
      "startServerCommand": "npm run preview -- --host 127.0.0.1",
      "startServerReadyPattern": "localhost:(\\d+)",
      "startServerReadyTimeout": 30000,
      "numberOfRuns": 3,
      "settings": {
        "throttlingMethod": "devtools"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.8 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 300 }],
        "speed-index": ["warn", { "maxNumericValue": 3400 }],
        "interactive": ["warn", { "maxNumericValue": 5000 }],
        "bf-cache": "off",
        "forced-reflow-insight": "off",
        "label-content-name-mismatch": "off",
        "list": "off",
        "network-dependency-tree-insight": "off",
        "total-byte-weight": ["warn", { "maxNumericValue": 600000 }],
        "unused-css-rules": ["warn", { "maxLength": 100 }],
        "unused-javascript": ["warn", { "maxLength": 100 }],
        "render-blocking-insight": ["warn", { "maxLength": 10 }],
        "render-blocking-resources": ["warn", { "maxLength": 10 }],
        "mainthread-work-breakdown": "off",
        "max-potential-fid": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
